</node>
<node id="Semiconductor and Related Industries">
  <data key="d0">Semiconductor and Related Industries</data>
  <data key="d1">industry</data>
  <data key="d2">The Semiconductor and Related Industries are the sectors to which AMAT provides equipment, services, and software, including manufacturers of semiconductor wafers, chips, and other electronic devices.&gt;</data>
  <data key="d3">chunk-26fa1d1070f941c3c83605779a2af8f0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
