</node>
<node id="200mm">
  <data key="d0">200mm</data>
  <data key="d1">concept</data>
  <data key="d2">200mm refers to the size of equipment shipped by AMAT to many customers globally, serving the non-leading-edge market.&gt;</data>
  <data key="d3">chunk-26fa1d1070f941c3c83605779a2af8f0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
