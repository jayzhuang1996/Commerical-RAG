  <data key="d0">Accounts Receivable</data>
  <data key="d1">data</data>
  <data key="d2">Accounts Receivable represents the money owed to the company for goods or services provided, which the company has sold on credit.</data>
  <data key="d3">chunk-b976a275590777e7877d2d66b5f6379c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
  <data key="d6"></data>
</node>
<node id="Days Sales Outstanding">
  <data key="d0">Days Sales Outstanding</data>
  <data key="d1">data</data>
  <data key="d2">Days Sales Outstanding is a measure of the average number of days it takes a company to collect payment after a sale has been made.</data>
  <data key="d3">chunk-b976a275590777e7877d2d66b5f6379c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
  <data key="d6"></data>
</node>
<node id="Capital Expenditures">
  <data key="d0">Capital Expenditures</data>
  <data key="d1">data</data>
  <data key="d2">Capital Expenditures are funds used by a company to acquire, upgrade, or improve physical assets such as property, industrial buildings, or equipment.&lt;SEP&gt;Capital Expenditures are funds used by a company to acquire, upgrade, and maintain physical assets, amounting to -$646 in 2026 and -$381 in 2025.&lt;SEP&gt;Capital Expenditures is a category in the cash flows from investing activities, with expenses of -646 and -381 in two different periods.&lt;SEP&gt;Capital Expenditures decreased by $7.9 million, affecting cash flows from investing activities.&lt;SEP&gt;Capital expenditures are funds used by a company to acquire, upgrade, or maintain physical assets.</data>
  <data key="d3">chunk-b976a275590777e7877d2d66b5f6379c&lt;SEP&gt;chunk-43a8f055527dad4e87136bbd01caf743&lt;SEP&gt;chunk-b33403642cf163673735a8236b77616c&lt;SEP&gt;chunk-6914852673b586e472efa313d90a7cbf&lt;SEP&gt;chunk-fcbd467e0d3d2d1e90e50929e4ef4372</data>
