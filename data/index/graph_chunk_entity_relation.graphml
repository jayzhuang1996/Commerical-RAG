  <data key="d0">Acquired Businesses</data>
  <data key="d1">organization</data>
  <data key="d2">Acquired Businesses are entities that have been purchased and are integrated into the operations of the acquiring company.</data>
  <data key="d3">chunk-99b76900a97d7c959bc5ca885c3601da</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
