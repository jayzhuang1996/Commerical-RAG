  <data key="d5">1777380497</data>
  <data key="d6"></data>
</node>
<node id="2023 Term Loans">
  <data key="d0">2023 Term Loans</data>
  <data key="d1">data</data>
  <data key="d2">A financial instrument used by Broadcom to fund the cash portion of the VMware Merger.&lt;SEP&gt;The 2023 Term Loans refer to the financial instrument used by Broadcom to fund the cash portion of the VMware Merger.&gt;&lt;SEP&gt;A financial instrument used by Broadcom to fund the cash portion of the VMware Merger.&lt;SEP&gt;The 2023 Term Loans refer to the financial instrument used by Broadcom to fund the cash portion of the VMware Merger.&gt;</data>
  <data key="d3">chunk-cb82fb0b57380bdf7abd3bbcae084048&lt;SEP&gt;chunk-5128d467897e9a6a1ea6d801c0966d6e</data>
