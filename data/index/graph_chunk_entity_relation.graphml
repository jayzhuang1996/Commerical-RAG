<node id="Agentic AI">
  <data key="d0">Agentic AI</data>
  <data key="d1">concept</data>
  <data key="d2">Agentic AI refers to the shift in AI from training models to deploying continuously running agents that reason, plan, and act, driving a major inflection point in global computing and increasing the demand for CPUs.</data>
  <data key="d3">chunk-2d1f6742e80ed84d267cfe46fa7c9e31</data>
