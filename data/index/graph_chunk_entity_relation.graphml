  <data key="d1">artifact</data>
  <data key="d2">IoT Microprocessors are small, power-efficient processors used in Internet of Things devices, often requiring embedded neural processing units.</data>
  <data key="d3">chunk-5068f4b1da4cd023617e872a463eeb62</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262483</data>
