<node id="Chief Information Security Officer">
  <data key="d0">Chief Information Security Officer</data>
  <data key="d1">person</data>
  <data key="d2">The Chief Information Security Officer (CISO) is an executive responsible for managing the company's cybersecurity risk management program.&lt;SEP&gt;The Chief Information Security Officer (CISO) is primarily responsible for managing the cybersecurity risk management program and has extensive experience in cybersecurity and information security management.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8&lt;SEP&gt;chunk-f533007cd8f65f3f88984fedd522d05d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
  <data key="d6"></data>
</node>
<node id="Audit Committee">
  <data key="d0">Audit Committee</data>
  <data key="d1">organization</data>
  <data key="d2">The Audit Committee is a subcommittee of the Board of Directors that oversees the enterprise risk management program, including cybersecurity risks.&lt;SEP&gt;The Audit Committee is a body to which the CISO reports at least quarterly on cybersecurity, data, and intellectual property security programs, policies, risks, and controls.&lt;SEP&gt;The Audit Committee is a board committee responsible for overseeing the company's financial reporting and internal controls.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8&lt;SEP&gt;chunk-f533007cd8f65f3f88984fedd522d05d&lt;SEP&gt;chunk-d780eacfb91e291d22055bf3aca31fa3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777307810</data>
  <data key="d6"></data>
</node>
<node id="Board">
  <data key="d0">Board</data>
  <data key="d1">organization</data>
  <data key="d2">The full Board is a recipient of annual reports from the CISO on cybersecurity, data, and intellectual property security programs, policies, risks, and controls.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
  <data key="d6"></data>
</node>
<node id="Chief Information Officer">
  <data key="d0">Chief Information Officer</data>
  <data key="d1">person</data>
  <data key="d2">The Chief Information Officer is responsible for administering secure and scalable security infrastructure and is the superior to whom the CISO reports.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
  <data key="d6"></data>
</node>
<node id="Chief Digital Officer">
  <data key="d0">Chief Digital Officer</data>
  <data key="d1">person</data>
  <data key="d2">The Chief Digital Officer is responsible for overseeing the Chief Information Officer and has extensive experience in information technology.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
