  <data key="d6"></data>
</node>
<node id="USD">
  <data key="d0">USD</data>
  <data key="d1">data</data>
  <data key="d2">The USD is the currency in which the majority of the company's revenue is denominated.</data>
  <data key="d3">chunk-5b11abf58ed4d75a128d8d943d08096f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262484</data>
  <data key="d6"></data>
</node>
<node id="Selling, General and Administrative Expenses">
  <data key="d0">Selling, General and Administrative Expenses</data>
