  <data key="d1">concept</data>
  <data key="d2">Technology Licensing Agreements (TLA) are agreements where a single CPU design or other technology design is licensed for a fixed fee.</data>
  <data key="d3">chunk-9fe18d577f076ce03948540ed8563a5c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262486</data>
