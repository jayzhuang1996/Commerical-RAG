  <data key="d3">chunk-13f18e1b9ab8662fc4105918eb9e67e8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="Share-based Compensation">
  <data key="d0">Share-based Compensation</data>
  <data key="d1">concept</data>
  <data key="d2">Share-based Compensation refers to the expense recorded for share-based awards over the requisite service periods.&gt;&lt;SEP&gt;Share-based Compensation refers to the accounting practice of expensing awards over the service periods, typically equivalent to the vesting term, and is only recorded for awards expected to vest.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c&lt;SEP&gt;chunk-1fc03c6340e9f91435287101b7ba57e5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="RSUs">
  <data key="d0">RSUs</data>
  <data key="d1">financialinstrument</data>
  <data key="d2">RSUs stands for Restricted Stock Units, which have a fair value based on the grant date fair value for share-based awards based on the closing price of the Company’s ADSs on Nasdaq.&gt;&lt;SEP&gt;RSUs are awards with a fair value based on the grant date fair value for share-based awards, calculated using the closing price of the Company’s ADSs on Nasdaq.&gt;&lt;SEP&gt;RSUs are part of INTC's equity incentive plans and are treated as common stock repurchases for tax purposes.|&lt;SEP&gt;RSUs stands for Restricted Stock Units, which are part of the equity incentive plans for employees.|&lt;SEP&gt;RSUs refer to Restricted Stock Units, which are part of INTC's equity incentive plans.|&lt;SEP&gt;RSUs are part of the company's equity incentive plans, and shares withheld for tax purposes on RSUs vesting are treated as common stock repurchases.|</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c&lt;SEP&gt;chunk-1fc03c6340e9f91435287101b7ba57e5&lt;SEP&gt;chunk-f60be1d369008dda0461cefaf2ff61fa&lt;SEP&gt;chunk-c4845686f7704c5c80e402305d19f7ce&lt;SEP&gt;chunk-77d86694dce1fc1e9c3d3ac3bab4c5be&lt;SEP&gt;chunk-01ee832930ff813d9db8fa5bfa02507e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777306028</data>
  <data key="d6"></data>
</node>
<node id="PSUs">
  <data key="d0">PSUs</data>
  <data key="d1">concept</data>
  <data key="d2">PSUs stands for Performance Stock Units, which are granted with relative total shareholder return.&gt;&lt;SEP&gt;PSUs are awards granted with relative total shareholder return as the performance measure under the Omnibus Incentive Plan, with vesting potential between 0% and 200% of the original award amount.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c&lt;SEP&gt;chunk-1fc03c6340e9f91435287101b7ba57e5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="Relative TSR">
  <data key="d0">Relative TSR</data>
  <data key="d1">concept</data>
  <data key="d2">Relative TSR is the performance measure used for PSUs, measured over a three-year period relative to the S&amp;P 500 IT Sector Index.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="Omnibus Incentive Plan">
  <data key="d0">Omnibus Incentive Plan</data>
  <data key="d1">concept</data>
  <data key="d2">The Omnibus Incentive Plan is the plan under which the Company grants PSUs with Relative TSR as the performance measure.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="Monte Carlo simulation model">
  <data key="d0">Monte Carlo simulation model</data>
  <data key="d1">method</data>
  <data key="d2">The Monte Carlo simulation model is used to determine the grant date fair value of the market conditions component of awards with Relative TSR-based performance measures.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
<node id="S&amp;P 500 IT Sector Index">
  <data key="d0">S&amp;P 500 IT Sector Index</data>
  <data key="d1">concept</data>
  <data key="d2">The S&amp;P 500 IT Sector Index is a benchmark used to measure the performance of PSUs with Relative TSR as the performance measure.&gt;</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262485</data>
  <data key="d6"></data>
</node>
