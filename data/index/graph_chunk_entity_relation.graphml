<node id="Estimates on Sales-Based Royalty Revenue Accruals">
  <data key="d0">Estimates on Sales-Based Royalty Revenue Accruals</data>
  <data key="d1">method</data>
  <data key="d2">Estimates on Sales-Based Royalty Revenue Accruals involve calculating expected royalties based on the sales of licensed products, taking into account macroeconomic effects and historical data.</data>
  <data key="d3">chunk-f5952f8b9b70d6c7a8ac3693a20d7033</data>
  <data key="d4">unknown_source</data>
