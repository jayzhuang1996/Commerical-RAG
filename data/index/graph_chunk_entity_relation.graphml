  <data key="d0">Income (loss) from equity investments, net</data>
  <data key="d1">data</data>
  <data key="d2">Income (loss) from equity investments, net represents the net gains or losses from the company's investments in other entities.</data>
  <data key="d3">chunk-1bd342ebc79b6c8d6a4c0db7019159b3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262484</data>
  <data key="d6"></data>
</node>
<node id="Interest income, net">
  <data key="d0">Interest income, net</data>
  <data key="d1">data</data>
  <data key="d2">Interest income, net is the net interest earned from the company's interest-bearing assets.</data>
  <data key="d3">chunk-1bd342ebc79b6c8d6a4c0db7019159b3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262484</data>
  <data key="d6"></data>
</node>
<node id="Other non-operating income (loss), net">
  <data key="d0">Other non-operating income (loss), net</data>
  <data key="d1">data</data>
  <data key="d2">Other non-operating income (loss), net includes all other income or expenses not related to the company's primary operations.</data>
  <data key="d3">chunk-1bd342ebc79b6c8d6a4c0db7019159b3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262484</data>
  <data key="d6"></data>
</node>
<node id="Income (loss) before income taxes">
  <data key="d0">Income (loss) before income taxes</data>
  <data key="d1">data</data>
  <data key="d2">Income (loss) before income taxes is the company's profit or loss before considering the impact of income taxes.</data>
  <data key="d3">chunk-1bd342ebc79b6c8d6a4c0db7019159b3</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262484</data>
  <data key="d6"></data>
</node>
<node id="Net income (loss)">
  <data key="d0">Net income (loss)</data>
  <data key="d1">data</data>
  <data key="d2">Net income (loss) is the company's final profit or loss after all revenues, expenses, and income taxes have been accounted for.</data>
  <data key="d3">chunk-1bd342ebc79b6c8d6a4c0db7019159b3</data>
