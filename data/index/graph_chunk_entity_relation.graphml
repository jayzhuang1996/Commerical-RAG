</node>
<node id="United Kingdom">
  <data key="d0">United Kingdom</data>
  <data key="d1">location</data>
  <data key="d2">The United Kingdom is one of the jurisdictions where the Company is subject to income taxes.&gt;&lt;SEP&gt;The United Kingdom has implemented legislation mirroring the GDPR and regulates data protection within its jurisdiction.</data>
  <data key="d3">chunk-8e2d85f7a44ae4d46a5296c95183929c&lt;SEP&gt;chunk-4745e08e8ad64a5ebc8a1bec6520d4f8</data>
