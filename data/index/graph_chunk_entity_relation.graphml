  <data key="d0">Business and Industry Risks</data>
  <data key="d1">concept</data>
  <data key="d2">Business and Industry Risks are the potential adverse impacts and uncertainties related to changes in trade policies, increased tariffs, and trade disputes.</data>
  <data key="d3">chunk-e7481c513c84b894dbf5566a03c9c31d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259231</data>
