  <data key="d1">agreement</data>
  <data key="d2">Arm Flexible Access agreements offer customers access to a range of processor, graphics, and systems products, with a low-cost annual portfolio license fee and a fee at tape-out.</data>
  <data key="d3">chunk-ca207bb382651453029b45cb72e9feff</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262486</data>
