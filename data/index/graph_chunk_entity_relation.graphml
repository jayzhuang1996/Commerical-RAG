<node id="Government Regulators">
  <data key="d0">Government Regulators</data>
  <data key="d1">organization</data>
  <data key="d2">Government Regulators are entities that impose requirements and review transactions, including post-closing investigations of non-notified transactions.</data>
  <data key="d3">chunk-99b76900a97d7c959bc5ca885c3601da</data>
