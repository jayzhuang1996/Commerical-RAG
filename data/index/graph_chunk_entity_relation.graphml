<node id="Arm Holdings plc">
  <data key="d0">Arm Holdings plc</data>
  <data key="d1">organization</data>
  <data key="d2">Arm Holdings plc is a technology company that announced the expansion of its compute platform to include production silicon products for the first time in the company's history, with a focus on AI data centers. It is listed on NASDAQ with the ticker ARM.</data>
  <data key="d3">chunk-2d1f6742e80ed84d267cfe46fa7c9e31</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777308127</data>
