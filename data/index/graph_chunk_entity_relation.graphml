  <data key="d0">Global National Security Regimes</data>
  <data key="d1">concept</data>
  <data key="d2">Global National Security Regimes refer to the expanding security measures that impose restrictions on foreign investments and acquisitions of local businesses.</data>
  <data key="d3">chunk-99b76900a97d7c959bc5ca885c3601da</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777260109</data>
