  <data key="d0">Israel</data>
  <data key="d1">location</data>
  <data key="d2">Israel is one of the primary locations where AMAT conducts its product development and manufacturing activities.&gt;</data>
  <data key="d3">chunk-26fa1d1070f941c3c83605779a2af8f0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
  <data key="d6"></data>
</node>
<node id="Asia">
  <data key="d0">Asia</data>
  <data key="d1">location</data>
  <data key="d2">Asia is one of the primary locations where AMAT conducts its product development and manufacturing activities.&gt;&lt;SEP&gt;Asia is a region where the organization conducts certain manufacturing, supply chain, and other operations to be closer to customers and reduce costs.</data>
  <data key="d3">chunk-26fa1d1070f941c3c83605779a2af8f0&lt;SEP&gt;chunk-7200d8553fd2e4a1586cd2f8af4129fc</data>
