<node id="Fair Value">
  <data key="d0">Fair Value</data>
  <data key="d1">financialmetric</data>
  <data key="d2">Fair value is the price that would be received to sell an asset or paid to transfer a liability in an orderly transaction between market participants.</data>
  <data key="d3">chunk-37906de44c22f23501372f2b90cd5aa7</data>
  <data key="d4">unknown_source</data>
