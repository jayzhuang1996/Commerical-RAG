</node>
<node id="Unsecured Borrowings">
  <data key="d0">Unsecured Borrowings</data>
  <data key="d1">data</data>
  <data key="d2">Unsecured Borrowings refer to loans taken by the company without providing any collateral; the company has credit facilities for such borrowings up to an aggregate amount of $4.1 billion.</data>
  <data key="d3">chunk-b976a275590777e7877d2d66b5f6379c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777259232</data>
