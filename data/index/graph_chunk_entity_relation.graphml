<node id="Support and Maintenance">
  <data key="d0">Support and Maintenance</data>
  <data key="d1">service</data>
  <data key="d2">Support and maintenance services are offered, with an annual fee required for a minimum of one year.</data>
  <data key="d3">chunk-ca207bb382651453029b45cb72e9feff</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1777262486</data>
