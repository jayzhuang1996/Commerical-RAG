  <data key="d5">1777307809</data>
  <data key="d6"></data>
</node>
<node id="Investment Portfolio">
  <data key="d0">Investment Portfolio</data>
  <data key="d1">category</data>
  <data key="d2">The Investment Portfolio consists of various financial instruments and securities the company holds for potential profit or to manage risk.&lt;SEP&gt;The Investment Portfolio consists of corporate and government securities, money market funds, and other debt and equity investments held by the company.</data>
  <data key="d3">chunk-b976a275590777e7877d2d66b5f6379c&lt;SEP&gt;chunk-120a4f2fbe48d0891e48fba271c88ec1</data>
