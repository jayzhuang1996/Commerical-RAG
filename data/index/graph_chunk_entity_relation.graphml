<node id="Total Operating Expenses">
  <data key="d0">Total Operating Expenses</data>
  <data key="d1">category</data>
  <data key="d2">Total operating expenses for fiscal year 2026 were $23,076 million, showing a 41% increase from the previous year.</data>
