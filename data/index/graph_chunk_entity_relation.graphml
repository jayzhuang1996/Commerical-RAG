  <data key="d6"></data>
</node>
<node id="Cybersecurity Incident Response Plan">
  <data key="d0">Cybersecurity Incident Response Plan</data>
  <data key="d1">method</data>
  <data key="d2">The Cybersecurity Incident Response Plan is a protocol managed by the CISO for responding to cybersecurity incidents.</data>
  <data key="d3">chunk-d30ee8565f60986af2412d44782de3b8</data>
